---
import DemoLayout from '../../layouts/DemoLayout.astro';
import DemoFraming from '../../components/DemoFraming.astro';
import { demos, demoSchema } from '../../data/demos';
import ReviewAutopilot from '../../components/demos/review-autopilot/Dashboard';
import DemoAbout from '../../components/DemoAbout.astro';
import IslandSkeleton from '../../components/IslandSkeleton.astro';
// The five vertical heading faces — imported here (not in BaseLayout) so the
// ~150–200 KB of extra woff2 loads on this route only. The bridge vars in
// src/styles/review-autopilot.css map them onto the demo's skin tokens.
import '@fontsource-variable/oswald';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/rubik';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

const demo = demos.find((d) => d.slug === 'review-autopilot')!;
const schema = demoSchema(demo, new URL(Astro.site!).origin);
---

<DemoLayout
  title={demo.name}
  description={demo.seoDescription}
  image={`/og/${demo.slug}.png`}
  toolName={demo.name}
  schema={schema}
>
  <DemoFraming name={demo.name} tagline={demo.tagline} problem={demo.problem} does={demo.blurb} />
  <ReviewAutopilot client:only="react">
    <IslandSkeleton slot="fallback" name={demo.name} />
  </ReviewAutopilot>
  <DemoAbout name={demo.name} about={demo.about} ask={demo.ask} />
</DemoLayout>
