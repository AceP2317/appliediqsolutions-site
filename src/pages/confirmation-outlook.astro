---
/**
 * The flagship — a dedicated top-level page, on the main-street.astro pattern
 * (MarketingLayout + page-local sections + inline schema).
 *
 * NOT /work/<slug>/ and NOT an 8th demos.ts row, deliberately:
 *   - DemoLayout carries a "← Work" backlink and a "Live Demo" pill, while the
 *     page would be absent from the /work/ gallery (which builds from demos.ts).
 *     That reads as a bug.
 *   - demoSchema() asserts `isAccessibleForFree` and `operatingSystem: 'Web
 *     browser'`. Both are false of a rate-limited hosted Python service.
 *   - proofStats[0] says "Open any one in your browser" — true of the seven,
 *     false of this. The count and the claim are welded; adding an 8th row
 *     would make one of them a lie.
 *
 * All copy reads from src/data/flagship.ts, which carries the honesty contract:
 * the engine is measured frequencies over observed transitions — never call it
 * ML, a model, trained, or a forecast.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Button from '../components/Button.astro';
import { flagship } from '../data/flagship';

const origin = new URL(Astro.site!).origin;
const schema = [
  {
    '@type': 'SoftwareApplication',
    '@id': `${origin}/confirmation-outlook/#app`,
    name: flagship.name,
    applicationCategory: 'BusinessApplication',
    url: flagship.cta.href,
    author: { '@id': `${origin}/#organization` },
    description: flagship.body,
    // Deliberately NOT asserting isAccessibleForFree or operatingSystem — the
    // service is rate-limited and is not a browser-local app. See the note above.
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
      {
        '@type': 'ListItem',
        position: 2,
        name: flagship.name,
        item: `${origin}/confirmation-outlook/`,
      },
    ],
  },
];
---
<MarketingLayout
  schema={schema}
  title={`${flagship.name} — the flagship, live`}
  description={flagship.body}
  image="/og/confirmation-outlook.png?v=1"
  brains={['top-right', 'bottom-center']}
>
  {/* ── Hero — claim, CTAs, then the proof ─────────────────────────────── */}
  <section class="relative overflow-hidden border-b border-line">
    <div class="bg-grid bg-grid-fade pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="mx-auto max-w-4xl px-6 py-16 sm:py-20">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <p class="mono-label inline-flex items-center gap-2">
          <span class="status-dot"></span>
          {flagship.eyebrow}
        </p>
        <span class="mono-label text-ink-faint">{flagship.host}</span>
      </div>

      <h1 class="mt-5 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
        {flagship.name}
      </h1>
      <p class="mt-3 text-xl leading-relaxed">
        <span class="aiq-accent">{flagship.tagline}</span>
      </p>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">{flagship.body}</p>

      {/* CTAs sit HIGH, directly under the pitch — the one thing this page
          exists to drive must never fall below the fold. */}
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <Button href={flagship.cta.href} variant="primary">{flagship.cta.label}</Button>
        <Button href={flagship.source.href} variant="secondary">{flagship.source.label}</Button>
      </div>

      {/* Static by construction: a committed screenshot, not an iframe or an
          uptime fetch. This page must render perfectly from the edge even when
          the demo box is dark. `.status-dot` is a pure-CSS pulse and asserts
          nothing about uptime. */}
      <img
        src="/shots/confirmation-outlook.webp"
        width="1200"
        height="630"
        loading="eager"
        decoding="async"
        alt="The Confirmation Outlook operator console — a risk register of orders ranked by probability of missing their confirmed date."
        class="mt-10 w-full rounded-xl border border-line shadow-2xl shadow-black/40"
      />
    </div>
  </section>

  {/* ── Fact strip — 4-up. (The old Opener panel ran these 2-up because it was
       5/12 of a grid and four mono labels collided at that width. At max-w-4xl
       that constraint is gone.) ──────────────────────────────────────────── */}
  <section class="border-b border-line">
    <dl class="mx-auto grid max-w-4xl grid-cols-2 gap-x-6 gap-y-5 px-6 py-8 sm:grid-cols-4">
      {flagship.facts.map((f) => (
        <div class="flex flex-col gap-1">
          <dd class="font-display text-2xl font-semibold text-ink">{f.v}</dd>
          <dt class="mono-label text-ink-faint">{f.k}</dt>
        </div>
      ))}
    </dl>
  </section>

  {/* ── /01 How it's built ─────────────────────────────────────────────── */}
  <section class="section-band">
    <div class="mx-auto max-w-4xl px-6 py-16 sm:py-20">
      <p class="flex items-center gap-2.5">
        <span class="section-index">/ 01</span>
        <span class="mono-label">How it’s built</span>
      </p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
        The restraint is the point.
      </h2>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-muted">
        Anyone can bolt a model onto a dashboard and call the output a forecast. This one only ever
        tells you what it actually measured — and refuses to ship if the numbers don’t hold.
      </p>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {flagship.arch.map((a) => (
          <div class="panel flex flex-col gap-2 p-6">
            <h3 class="font-display text-lg font-semibold text-ink">{a.title}</h3>
            <p class="text-sm leading-relaxed text-ink-muted">{a.body}</p>
          </div>
        ))}
      </div>

      <p class="mono-label mt-8 text-ink-faint">{flagship.honesty}</p>
    </div>
  </section>

  {/* ── Closing CTA ────────────────────────────────────────────────────── */}
  <section class="mx-auto max-w-4xl px-6 py-16 text-center sm:py-20">
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      This is what I ship. Yours would be built the same way.
    </h2>
    <p class="mx-auto mt-4 max-w-xl leading-relaxed text-ink-muted">
      Built end to end for a fictional manufacturer — engine, API, and console. Tell me the problem
      your operation is actually carrying, and I’ll tell you straight how I’d build the fix.
    </p>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
      <Button href="/contact/?intent=quote" variant="primary">Start a project</Button>
      <Button href={flagship.cta.href} variant="secondary">{flagship.cta.label}</Button>
    </div>
  </section>
</MarketingLayout>
