---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Button from '../components/Button.astro';
---
<MarketingLayout
  title="Page not found"
  description="That page doesn't exist — here's the way back to the live tools and everything else."
  brains={['bottom-center']}
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-start justify-center px-6 py-24">
    <p class="mono-label">Error · 404</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      That page isn’t here.
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-muted">
      The link may be old or mistyped. The live tools and everything else are one click away.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/" arrow="none">Back to home</Button>
      <Button href="/work/" variant="secondary">See the live tools</Button>
    </div>
  </section>
</MarketingLayout>
