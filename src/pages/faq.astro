---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Faq from '../components/Faq.astro';
import Button from '../components/Button.astro';
import AskTooling from '../components/AskTooling.jsx';
import IslandSkeleton from '../components/IslandSkeleton.astro';
import { faq } from '../data/home';

// FAQPage structured data (SEO). Answers may carry inline HTML (e.g. links) —
// strip tags for the plain-text schema answer.
const stripTags = (s: string) => s.replace(/<[^>]*>/g, '');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: stripTags(f.a) },
  })),
};
---
<MarketingLayout
  title="FAQ"
  description="Straight answers before you start: what I build, how fast, security and data ownership, and what a first engagement looks like."
  image="/og/faq.png?v=1"
  brains={['top-right', 'bottom-center']}
>
  {/* ── Intro ─────────────────────────────────────────────────────────── */}
  <section class="relative overflow-hidden border-b border-line">
    <div class="bg-grid bg-grid-fade pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="mx-auto max-w-4xl px-6 py-16 sm:py-24">
      <p class="mono-label">FAQ</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
        Questions before you start.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">
        The straight version — what I build, how fast, who owns the output, and what the first
        step actually looks like.
      </p>
    </div>
  </section>

  {/* ── The questions ─────────────────────────────────────────────────── */}
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <Faq items={faq} />
  </section>

  {/* ── Ask the assistant (live) ──────────────────────────────────────── */}
  <section class="mx-auto max-w-3xl px-6 pb-16 sm:pb-20">
    <p class="mono-label inline-flex items-center gap-2">
      <span class="status-dot"></span>
      Ask · live
    </p>
    <h2 class="mt-4 font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      Didn’t find it? Ask the assistant.
    </h2>
    <p class="mt-3 max-w-2xl leading-relaxed text-ink-muted">
      A live assistant in Ian’s voice — put your question to the tooling directly and get a straight,
      on-the-spot read. For a real quote or a commitment, it points you to Ian.
    </p>
    <AskTooling client:only="react">
      <IslandSkeleton slot="fallback" variant="chat" />
    </AskTooling>
  </section>

  {/* ── Light CTA — the human path ────────────────────────────────────── */}
  <section class="mx-auto max-w-4xl px-6 pb-20 text-center sm:pb-28">
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      Rather ask Ian directly?
    </h2>
    <p class="mx-auto mt-4 max-w-xl leading-relaxed text-ink-muted">
      Ask it straight — I read every message myself, and you’ll get an honest read on the problem
      and how I’d build it.
    </p>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
      <Button href="/contact/" variant="primary">Ask me directly</Button>
      <Button href="/work/" variant="secondary">See the live tools</Button>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</MarketingLayout>
