---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import ContactForm from '../components/ContactForm.jsx';
import { socialLinks } from '../data/links';

const linkedin = socialLinks.find((s) => s.id === 'linkedin')!;
const email = 'contact@appliediqsolutions.com';
const next = [
  { n: '1', t: 'I read it myself', b: 'No sales team, no funnel — your message comes straight to me.' },
  { n: '2', t: 'I reply within one business day', b: 'A straight read on the problem — and how I’d build it.' },
  { n: '3', t: 'We scope it on a call', b: 'The first conversation is free. We turn the problem into a plan for a working tool.' },
];
---
<MarketingLayout
  title="Contact"
  description="Start a project with AppliedIQ — request a quote, a consult, or send a question. Custom software for the hard, one-off problems your systems never solved."
>
  {/* ── Hero ──────────────────────────────────────────────────────────── */}
  <section class="relative overflow-hidden border-b border-line">
    <div class="bg-grid bg-grid-fade pointer-events-none absolute inset-0 -z-10 opacity-60"></div>
    <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <p class="mono-label">Start a project</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
        The problem your software never solved — that’s exactly what I solve.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">
        Tell me the one thing your systems never did for you. Whatever it is, we’ll build it — and
        you’ll own it. Pick how you’d like to start — a quote, a consult, or just a
        question — and I’ll take it from there.
      </p>
    </div>
  </section>

  {/* ── Engagement hub: intent-routed form + what-happens-next ────────── */}
  <section class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:gap-16">
      <div>
        <ContactForm client:load />
      </div>

      <aside class="flex flex-col gap-10">
        <div>
          <p class="mono-label">What happens next</p>
          <ol class="mt-5 flex flex-col gap-5">
            {next.map((s) => (
              <li class="flex gap-4">
                <span class="process-node shrink-0">{s.n}</span>
                <div>
                  <h2 class="font-display text-base font-semibold text-ink">{s.t}</h2>
                  <p class="mt-1 text-sm leading-relaxed text-ink-muted">{s.b}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="panel lift spotlight p-6">
          <p class="mono-label">Prefer email?</p>
          <p class="mt-2 text-sm leading-relaxed text-ink-muted">
            You’re emailing me, not a sales team — and I read every message myself.
          </p>
          <a
            href={`mailto:${email}`}
            class="link-sweep group mt-3 inline-flex items-center gap-2 text-sm font-medium"
          >
            {email}
            <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
          </a>
          <p class="mt-4 text-sm leading-relaxed text-ink-muted">
            Or connect on
            <a href={linkedin.href} target="_blank" rel="noopener" class="link-sweep font-medium">LinkedIn</a>.
          </p>
        </div>
      </aside>
    </div>
  </section>
</MarketingLayout>
