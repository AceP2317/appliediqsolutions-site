---
/**
 * ShipLog — the "hours, not quarters" velocity claim converted into
 * machine-timestamped evidence: a curated timeline of this site's own commits.
 * Rows come from src/data/receipts.json, generated by `npm run receipts`, which
 * verifies every hash + timestamp against git before it will emit a row — the
 * labels are curated, the timestamps are git's own. Verbs stay honest:
 * `ported` (finished build moved onto the site) vs `built` vs `shipped` vs
 * `autonomous` (no human in the loop).
 */
import receipts from '../data/receipts.json';
import { demos } from '../data/demos';

const NY = 'America/New_York';
const fmtDate = new Intl.DateTimeFormat('en-US', { timeZone: NY, month: 'short', day: 'numeric', year: 'numeric' });
const fmtTime = new Intl.DateTimeFormat('en-US', { timeZone: NY, hour: 'numeric', minute: '2-digit', hour12: false });
const rows = receipts.milestones.map((m) => {
  const d = new Date(m.iso);
  return { ...m, date: fmtDate.format(d), time: fmtTime.format(d) };
});
const days = Math.max(1, Math.ceil((Date.now() - +new Date(receipts.firstCommitIso)) / 86_400_000));

const verbStyle: Record<string, string> = {
  built: 'border-accent/40 text-accent-2',
  ported: 'border-line-2 text-ink-muted',
  shipped: 'border-cyan-deep/40 text-cyan-deep',
  autonomous: 'border-label/50 text-label',
};

const stats = [
  { v: String(receipts.totalCommits), l: 'commits' },
  { v: String(days), l: 'days' },
  { v: String(demos.length), l: 'live tools' },
  { v: '1', l: 'autonomous pipeline' },
];
---
<section id="ship-log" class="section-band">
  <div class="mx-auto max-w-4xl px-6 py-16 sm:py-20">
    <p class="flex items-center gap-2.5">
      <span class="section-index">/ 05</span>
      <span class="mono-label">The ship log</span>
    </p>
    <h2 class="mt-3 max-w-2xl font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      “Hours, not quarters” — receipted.
    </h2>
    <p class="mt-4 max-w-2xl leading-relaxed text-ink-muted">
      Every row below is a real commit in this site’s repository. The timestamps are git’s own —
      machine-recorded when the work shipped, not written for marketing. This is the cadence the
      practice runs at, on its own product.
    </p>

    <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
      {stats.map((s) => (
        <div class="flex items-baseline gap-2">
          <span class="font-display text-2xl font-semibold text-ink">{s.v}</span>
          <span class="mono-label">{s.l}</span>
        </div>
      ))}
    </div>

    <ol class="mt-10">
      {rows.map((r) => (
        <li class="relative border-l border-line pb-8 pl-6 last:pb-0">
          <span
            class:list={[
              'absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full border',
              r.verb === 'autonomous' ? 'border-label bg-label/30' : 'border-line-2 bg-surface-2',
            ]}
            aria-hidden="true"
          ></span>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span class="font-mono text-xs tracking-wide text-ink-faint">{r.date} · {r.time} ET</span>
            <span class="font-mono text-[0.65rem] text-ink-faint/70">{r.hash}</span>
            <span class:list={['mono-label rounded border px-1.5 py-0.5 text-[0.55rem]', verbStyle[r.verb]]}>
              {r.verb}
            </span>
          </div>
          <p class="mt-2 max-w-2xl leading-relaxed text-ink-muted">{r.label}</p>
        </li>
      ))}
    </ol>

    <p class="mt-8 max-w-2xl text-sm leading-relaxed text-ink-faint">
      Generated from the repository by a script that refuses to emit a row it can’t verify against
      git (as of <span class="font-mono">{receipts.generatedFrom}</span>). The working repo is
      private, so the hashes above aren’t externally clickable; a sanitized single-snapshot mirror
      (current code, no history) is public at{' '}
      <a
        href="https://github.com/AceP2317/appliediqsolutions-site"
        target="_blank"
        rel="noopener"
        class="link-sweep"
      >github.com/AceP2317/appliediqsolutions-site</a>.
    </p>
  </div>
</section>
