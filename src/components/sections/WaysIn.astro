---
/**
 * WaysIn — "two ways in": the vision turned into a concrete offer. Replaces the
 * drier Gap + Positioning argument blocks on the home page. Two roads — the small/
 * spreadsheet-run business (operationalize, then own the system) and the established
 * company stuck with rigid software (stop fighting it, build tailored) — both
 * ending at software the client owns. Copy lives in src/data/home.ts.
 */
import Section from '../Section.astro';
import SectionHead from '../SectionHead.astro';
import { paths, pathsHead } from '../../data/home';
---
<Section id="ways-in">
  <SectionHead index="/ 01" eyebrow="Two ways in" title={pathsHead.title} lede={pathsHead.lede} />

  <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
    {paths.map((p) => (
      <div class="panel p-7 sm:p-8">
        <p class="mono-label text-cyan-deep">{p.forWho}</p>
        <h3 class="mt-3 font-display text-xl font-semibold text-ink sm:text-2xl">{p.title}</h3>
        <p class="mt-4 leading-relaxed text-ink-muted">{p.body}</p>
      </div>
    ))}
  </div>
</Section>
