---
import Section from '../Section.astro';
import { fit } from '../../data/home';
import { Check, Minus } from '@lucide/astro';
---
<Section id="fit">
  <div class="max-w-3xl">
    <p class="flex items-center gap-2.5">
      <span class="section-index">/ 08</span>
      <span class="mono-label">Fit</span>
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      A fit — and a not-a-fit.
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-ink-muted">
      I’d rather be honest about where this works than win a project it doesn’t suit.
    </p>
  </div>

  <div class="mt-12 grid gap-4 md:grid-cols-2">
    <div class="panel p-7">
      <p class="mono-label text-up">A fit when</p>
      <ul class="mt-5 flex flex-col gap-3">
        {fit.fit.map((item) => (
          <li class="flex items-start gap-3 text-ink">
            <Check size={18} class="mt-0.5 shrink-0 text-up" aria-hidden="true" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="panel p-7">
      <p class="mono-label text-down">Not a fit if</p>
      <ul class="mt-5 flex flex-col gap-3">
        {fit.notFit.map((item) => (
          <li class="flex items-start gap-3 text-ink-muted">
            <Minus size={18} class="mt-0.5 shrink-0 text-down" aria-hidden="true" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>
