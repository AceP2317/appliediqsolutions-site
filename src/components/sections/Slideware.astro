---
import Section from '../Section.astro';
import { comparison } from '../../data/home';
import { X, Check } from '@lucide/astro';
---
<Section id="slideware">
  <div class="max-w-3xl">
    <p class="flex items-center gap-2.5">
      <span class="section-index">/ 06</span>
      <span class="mono-label">The difference</span>
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      Most AI consulting ends at the slide. Mine ends at the tool people use.
    </h2>
  </div>

  <div class="mt-12 grid gap-4 md:grid-cols-2">
    <div class="panel p-7">
      <p class="mono-label">{comparison.left.title}</p>
      <ul class="mt-5 flex flex-col gap-3">
        {comparison.left.items.map((item) => (
          <li class="flex items-start gap-3 text-ink-muted">
            <X size={18} class="mt-0.5 shrink-0 text-down" aria-hidden="true" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="panel border-accent/40 p-7">
      <p class="mono-label text-accent-2">{comparison.right.title}</p>
      <ul class="mt-5 flex flex-col gap-3">
        {comparison.right.items.map((item) => (
          <li class="flex items-start gap-3 text-ink">
            <Check size={18} class="mt-0.5 shrink-0 text-up" aria-hidden="true" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>
