---
import Section from '../Section.astro';
import SectionHead from '../SectionHead.astro';
import { process } from '../../data/home';
---
<Section id="process" tone="surface">
  <SectionHead
    index="/ 04"
    eyebrow="Method"
    title="Domain mastery, directed into working software."
    lede="Not “I use AI.” A repeatable method for compressing the distance between knowing the problem and shipping the fix."
    action={{ href: '/approach/', label: 'The full method' }}
  />

  <ol class="mt-12 flex flex-col gap-px overflow-hidden rounded-xl border border-line bg-line">
    {process.map((step) => (
      <li class="flex flex-col gap-4 bg-surface p-6 sm:flex-row sm:gap-6 sm:p-8">
        <span class="process-node shrink-0">{step.n}</span>
        <div>
          <h3 class="font-display text-xl font-semibold text-ink">{step.title}</h3>
          <p class="mt-2 max-w-2xl leading-relaxed text-ink-muted">{step.body}</p>
        </div>
      </li>
    ))}
  </ol>
</Section>
